{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "LLM Call Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(factory_worker_duration_seconds_bucket{type=\"llm\"}[5m])) by (le, worker))",
          "legendFormat": "{{worker}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(factory_worker_duration_seconds_bucket{type=\"llm\"}[5m])) by (le, worker))",
          "legendFormat": "{{worker}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(factory_worker_duration_seconds_bucket{type=\"llm\"}[5m])) by (le, worker))",
          "legendFormat": "{{worker}} p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never"
          },
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "LLM Calls/min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "rate(factory_step_count_total{type=\"llm\"}[1m])",
        "legendFormat": "{{worker}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "LLM Workers — Total Calls",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "factory_step_count_total{type=\"llm\"}",
        "legendFormat": "{{worker}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "LLM Error Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "id": 4,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "{service_name=\"factorio-brewery\"} | json | factory_worker_type=\"llm\" | level=\"error\"",
        "refId": "A"
      }],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "LLM Traces",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "id": 5,
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [{
        "queryType": "traceqlSearch",
        "filters": [
          { "id": "service-name", "tag": "service.name", "operator": "=", "value": ["factorio-brewery"], "scope": "resource" },
          { "id": "worker-type", "tag": "factory.worker_type", "operator": "=", "value": ["llm"], "scope": "span" }
        ],
        "limit": 20,
        "refId": "A"
      }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["factorio", "llm"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "title": "FACTORIO — LLM Performance",
  "uid": "factorio-llm"
}
