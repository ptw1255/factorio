{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Worker Throughput (steps/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "rate(factory_step_count_total[1m])",
        "legendFormat": "{{worker}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Active Processes",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(factory_active_processes)",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          },
          "min": 0,
          "max": 50
        },
        "overrides": []
      }
    },
    {
      "title": "LLM vs Automation Steps",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(factory_step_count_total{type=\"llm\"}[5m]))",
          "legendFormat": "LLM",
          "refId": "A"
        },
        {
          "expr": "sum(rate(factory_step_count_total{type=\"automation\"}[5m]))",
          "legendFormat": "Automation",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Worker Duration Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(factory_worker_duration_seconds_bucket[5m])) by (le, worker)",
        "format": "heatmap",
        "legendFormat": "{{le}}",
        "refId": "A"
      }],
      "options": {
        "calculate": false,
        "color": { "scheme": "Oranges", "mode": "scheme" },
        "yAxis": { "unit": "s" }
      }
    },
    {
      "title": "Worker Latency P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(factory_worker_duration_seconds_bucket[5m])) by (le, worker))",
        "legendFormat": "{{worker}} p95",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never"
          },
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Recent Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "{service_name=\"factorio-brewery\"} | json",
        "refId": "A"
      }],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "Recent Traces",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 7,
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [{
        "queryType": "traceqlSearch",
        "filters": [
          { "id": "service-name", "tag": "service.name", "operator": "=", "value": ["factorio-brewery"], "scope": "resource" }
        ],
        "limit": 20,
        "refId": "A"
      }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["factorio"],
  "templating": {
    "list": [{
      "name": "process",
      "type": "custom",
      "query": "brewing,bottling,crating,sales,materials,distribution,accounting",
      "current": { "text": "All", "value": "$__all" },
      "includeAll": true,
      "multi": true
    }]
  },
  "time": { "from": "now-15m", "to": "now" },
  "title": "FACTORIO — Factory Overview",
  "uid": "factorio-overview"
}
